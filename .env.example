# =============================================================================
# inkai-app — Dual Mode: Lokal vs Online
# =============================================================================
# Salin ke .env.local (dev) atau .env.production (prod), lalu isi nilai sesuai.
# Jangan commit .env.local / .env.production (sudah di .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# MODE LOKAL (Supabase local dev: supabase start)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<dari output `supabase start`>
# SUPABASE_SERVICE_ROLE_KEY=<dari output `supabase start`>

# -----------------------------------------------------------------------------
# MODE ONLINE (Supabase Cloud)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key dari Dashboard > Settings > API>
# SUPABASE_SERVICE_ROLE_KEY=<service_role key dari Dashboard > Settings > API>

# -----------------------------------------------------------------------------
# OPSIONAL — Root superadmin (env-based, bukan hard-coded)
# -----------------------------------------------------------------------------
# INKAI_ROOT_EMAIL=karateinkaisby@gmail.com
# NEXT_PUBLIC_INKAI_ROOT_EMAIL=karateinkaisby@gmail.com

"use client";

import { useEffect, useState, useMemo, useCallback } from "react";
import * as LucideIcons from "lucide-react";
import type { LucideIcon } from "lucide-react";
import { FixedSizeGrid as Grid, GridChildComponentProps } from "react-window";
import type { MenuRow } from "./useMenuCRUD";

type Props = {
  open: boolean;
  onClose: () => void;
  initial?: Partial<MenuRow>;
  onSubmit: (payload: Partial<MenuRow>) => Promise<void>;
};

const ALL_ICONS: [string, LucideIcon][] = Object.entries(LucideIcons)
  .filter(([key, value]) => typeof value === "function" && /^[A-Z]/.test(key))
  .map(([key, value]) => [key, value as LucideIcon]);

const DEFAULT_ICON = (LucideIcons as any)["Circle"] ?? ALL_ICONS[0]?.[1];

const EMPTY: Partial<MenuRow> = {
  key: "",
  name: "",
  scope: "sidebar",
  icon: "Circle",
  order_index: 0,
  is_active: true,
  superadmin_only: false,
  context_required: false,
  required_structural_level: null,
  required_functional_role: null,
  color: null,
};

export default function MenuForm({ open, onClose, initial, onSubmit }: Props) {
  const [form, setForm] = useState<Partial<MenuRow>>(EMPTY);
  const [saving, setSaving] = useState(false);
  const [iconSearch, setIconSearch] = useState("");

  // Reset form saat open berubah
  useEffect(() => {
    if (open) {
      setForm(initial ? { ...EMPTY, ...initial } : EMPTY);
      setIconSearch("");
    }
  }, [open, initial]);

  const filteredIcons = useMemo(() => {
    return ALL_ICONS.filter(([name]) =>
      name.toLowerCase().includes(iconSearch.toLowerCase()),
    );
  }, [iconSearch]);

  const PreviewIcon =
    ALL_ICONS.find(([name]) => name === form.icon)?.[1] ?? DEFAULT_ICON;

  const columnCount = 8;
  const rowCount = Math.ceil(filteredIcons.length / columnCount);

  const Cell = useCallback(
    ({ columnIndex, rowIndex, style }: GridChildComponentProps) => {
      const index = rowIndex * columnCount + columnIndex;
      if (index >= filteredIcons.length) return null;

      const [name, Icon] = filteredIcons[index];
      const active = form.icon === name;

      return (
        <div style={style} className="p-1">
          <button
            type="button"
            onClick={() => setForm((prev) => ({ ...prev, icon: name }))}
            className={`w-full h-full flex items-center justify-center
              rounded border transition ${
                active
                  ? "border-emerald-500 bg-emerald-500/10"
                  : "border-white/10 hover:bg-white/5"
              }`}
          >
            <Icon size={18} />
          </button>
        </div>
      );
    },
    [filteredIcons, form.icon],
  );

  if (!open) return null;

  async function submit() {
    if (!form.name?.trim() || !form.key?.trim()) {
      alert("Nama dan Key wajib diisi");
      return;
    }

    try {
      setSaving(true);

      const payload: Partial<MenuRow> = {
        ...form,
        key: form.key.trim().toLowerCase(),
        name: form.name.trim(),
        order_index: Number(form.order_index ?? 0),
        scope: form.key === "dashboard" ? "sidebar" : form.scope,
      };

      await onSubmit(payload);
      // ⛔ Tidak panggil onClose di sini
    } catch (err: any) {
      alert(err?.message ?? "Terjadi kesalahan");
    } finally {
      setSaving(false);
    }
  }

  const isDashboard = form.key === "dashboard";

  return (
    <div
      className="fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-sm"
      onClick={onClose}
    >
      <div
        className="w-[760px] max-h-[92vh] flex flex-col rounded-xl border border-white/10 bg-[#0f172a] shadow-2xl"
        onClick={(e) => e.stopPropagation()}
      >
        <div className="px-6 py-4 border-b border-white/10">
          <h2 className="text-lg font-semibold">
            {initial?.id ? "Edit Menu" : "Tambah Menu"}
          </h2>
        </div>

        <div className="flex-1 overflow-y-auto px-6 py-6 space-y-6">
          {/* PREVIEW ICON */}
          <div className="flex items-center gap-3">
            <PreviewIcon size={22} />
            <span className="text-sm text-white/60">Preview Icon</span>
          </div>

          {/* INFORMASI */}
          <Section title="Informasi Dasar">
            <InputField
              label="Nama Menu"
              value={form.name ?? ""}
              onChange={(v) => setForm({ ...form, name: v })}
            />

            <InputField
              label="Key"
              value={form.key ?? ""}
              disabled={!!initial?.id}
              onChange={(v) => setForm({ ...form, key: v.toLowerCase() })}
            />

            <SelectField
              label="Scope"
              value={form.scope ?? "sidebar"}
              disabled={isDashboard}
              onChange={(v) => setForm({ ...form, scope: v as any })}
              options={[
                { value: "sidebar", label: "Sidebar" },
                { value: "settings", label: "Settings Only" },
              ]}
            />

            <InputField
              label="Order Index"
              type="number"
              value={form.order_index ?? 0}
              onChange={(v) =>
                setForm({
                  ...form,
                  order_index: Number(v),
                })
              }
            />
          </Section>

          {/* FLAGS */}
          <Section title="Flags">
            <CheckboxCard
              label="Aktif"
              checked={!!form.is_active}
              onChange={(v) => setForm({ ...form, is_active: v })}
            />
            <CheckboxCard
              label="Superadmin Only"
              checked={!!form.superadmin_only}
              onChange={(v) =>
                setForm({
                  ...form,
                  superadmin_only: v,
                })
              }
            />
            <CheckboxCard
              label="Context Required"
              checked={!!form.context_required}
              onChange={(v) =>
                setForm({
                  ...form,
                  context_required: v,
                })
              }
            />
          </Section>

          {/* ICON PICKER */}
          <Section title="Icon">
            <input
              type="text"
              placeholder="Cari icon..."
              value={iconSearch}
              onChange={(e) => setIconSearch(e.target.value)}
              className="input mb-3"
            />

            <Grid
              columnCount={columnCount}
              columnWidth={60}
              height={240}
              rowCount={rowCount}
              rowHeight={60}
              width={columnCount * 60}
            >
              {Cell}
            </Grid>
          </Section>
        </div>

        <div className="px-6 py-4 border-t border-white/10 flex justify-end gap-3">
          <button
            onClick={onClose}
            className="px-4 py-2 border border-white/20 rounded"
          >
            Batal
          </button>
          <button
            onClick={submit}
            disabled={saving}
            className="px-5 py-2 bg-emerald-600 rounded disabled:opacity-50"
          >
            {saving ? "Menyimpan..." : "Simpan"}
          </button>
        </div>
      </div>
    </div>
  );
}

/* ====================== UI COMPONENTS ====================== */

function Section({
  title,
  children,
}: {
  title: string;
  children: React.ReactNode;
}) {
  return (
    <div className="space-y-4">
      <div className="text-sm font-semibold text-white/80">{title}</div>
      {children}
    </div>
  );
}

function InputField({
  label,
  value,
  onChange,
  type = "text",
  disabled = false,
}: {
  label: string;
  value: string | number;
  onChange: (v: string) => void;
  type?: string;
  disabled?: boolean;
}) {
  return (
    <div className="space-y-1">
      <div className="text-sm font-medium">{label}</div>
      <input
        type={type}
        disabled={disabled}
        value={value}
        onChange={(e) => onChange(e.target.value)}
        className="input"
      />
    </div>
  );
}

function SelectField({
  label,
  value,
  onChange,
  options,
  disabled,
}: {
  label: string;
  value: string;
  onChange: (v: string) => void;
  options: { value: string; label: string }[];
  disabled?: boolean;
}) {
  return (
    <div className="space-y-1">
      <div className="text-sm font-medium">{label}</div>
      <select
        disabled={disabled}
        value={value}
        onChange={(e) => onChange(e.target.value)}
        className="input"
      >
        {options.map((o) => (
          <option key={o.value} value={o.value}>
            {o.label}
          </option>
        ))}
      </select>
    </div>
  );
}

function CheckboxCard({
  label,
  checked,
  onChange,
}: {
  label: string;
  checked: boolean;
  onChange: (v: boolean) => void;
}) {
  return (
    <label className="flex items-center gap-3 p-3 border border-white/10 rounded bg-black/20">
      <input
        type="checkbox"
        checked={checked}
        onChange={(e) => onChange(e.target.checked)}
      />
      <span>{label}</span>
    </label>
  );
}

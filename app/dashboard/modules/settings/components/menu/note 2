// app/dashboard/components/dashboard/canAccess.ts

export type MenuAccess = {
  key?: string;
  superadmin_only?: boolean;
  required_structural_level?: number | null;
  required_functional_role?: string | null;
  context_required?: boolean;
};

export type FunctionalRole = {
  role: string;
  active: boolean;
  context_id?: string;
};

export type SessionUserAccess = {
  email_allowed: boolean;
  app_role?: string | null;
  structural_level?: number | null;
  functional_roles?: FunctionalRole[];
};

const CORE_KEYS = ["dashboard", "home", "sidebar"];

export function canAccessMenu(
  menu: MenuAccess,
  user: SessionUserAccess,
): boolean {
  if (!user) return false;

  // 2️⃣ SUPERADMIN = ROOT SYSTEM
  if (user.app_role === "SUPERADMIN") return true;

  // 3️⃣ MENU KHUSUS SUPERADMIN
  if (menu.superadmin_only) return false;

  // 4️⃣ STRUKTURAL
  if (
    menu.required_structural_level !== null &&
    menu.required_structural_level !== undefined
  ) {
    if ((user.structural_level ?? 0) < menu.required_structural_level) {
      return false;
    }
  }

  // 5️⃣ FUNGSIONAL
  if (menu.required_functional_role) {
    const ok = user.functional_roles?.some(
      (r) => r.role === menu.required_functional_role && r.active === true
    );
    if (!ok) return false;
  }

  return true;
}


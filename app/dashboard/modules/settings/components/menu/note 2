"use client";

import { useEffect, useState, useCallback } from "react";
import { supabaseBrowser as supabase } from "@/app/lib/supabaseBrowser";

export type MenuRow = {
  id: string;
  key: string;
  name: string;
  order_index: number;
  is_active: boolean;
  superadmin_only: boolean;
  scope: "sidebar" | "settings" | null;
  icon: string | null;
  color: string | null;
  context_required: boolean;
  required_structural_level: number | null;
  required_functional_role: string | null;
};

export function useMenuCRUD() {
  const [menus, setMenus] = useState<MenuRow[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  const [isSuperadmin, setIsSuperadmin] = useState<boolean | null>(null);

  /* ================= SESSION CHECK ================= */
    const requireSession = async () => {
    const {
      data: { session },
    } = await supabase.auth.getSession();

    if (!session) {
      throw new Error("Session tidak ditemukan. Silakan login ulang.");
    }

    return session;
  };

  /* ================= FETCH USER ROLE ================= */
  const fetchUserRole = useCallback(async () => {
    try {
      await requireSession();

      const { data: userData } = await supabase.auth.getUser();
      if (!userData?.user) {
        setIsSuperadmin(false);
        return;
      }

      const { data: profile, error } = await supabase
        .from("profiles")
        .select("app_role")
        .eq("user_id", userData.user.id)
        .single();

      if (error) throw error;

      setIsSuperadmin(profile?.app_role === "SUPERADMIN");
    } catch (e: any) {
      setError(e.message);
      setIsSuperadmin(false);
    }
  }, []);

  /* ================= FETCH MENUS ================= */
  const fetchMenus = useCallback(async () => {
    try {
      await requireSession();

      const { data, error } = await supabase.rpc("get_all_menus");

      if (error) throw error;

      setMenus(data ?? []);
    } catch (e: any) {
      setError(e.message);
      setMenus([]);
    }
  }, []);

  /* ================= CRUD ================= */
const createMenu = async (payload: Partial<MenuRow>) => {
  await requireSession();
  if (!isSuperadmin) throw new Error("Forbidden");

  const { error } = await supabase.rpc("insert_menu_secure", {
    p_key: payload.key,
    p_name: payload.name,
    p_order_index: payload.order_index,
    p_is_active: payload.is_active,
    p_superadmin_only: payload.superadmin_only,
    p_scope: payload.scope,
    p_icon: payload.icon,
    p_color: payload.color,
    p_context_required: payload.context_required,
    p_required_structural_level: payload.required_structural_level,
    p_required_functional_role: payload.required_functional_role,
  });

  if (error) throw error;

  await fetchMenus();
};


const updateMenu = async (id: string, payload: Partial<MenuRow>) => {
  await requireSession();
  if (!isSuperadmin) throw new Error("Forbidden");

  const { error } = await supabase.rpc("update_menu_secure", {
    p_id: id,
    p_key: payload.key,
    p_name: payload.name,
    p_order_index: payload.order_index,
    p_is_active: payload.is_active,
    p_superadmin_only: payload.superadmin_only,
    p_scope: payload.scope,
    p_icon: payload.icon,
    p_color: payload.color,
    p_context_required: payload.context_required,
    p_required_structural_level: payload.required_structural_level,
    p_required_functional_role: payload.required_functional_role,
  });

  if (error) throw error;

  await fetchMenus();
};

const deleteMenu = async (id: string) => {
  await requireSession();
  if (!isSuperadmin) throw new Error("Forbidden");

  const { error } = await supabase.rpc("delete_menu_secure", {
    p_id: id,
  });

  if (error) throw error;

  await fetchMenus();
};


  /* ================= INIT ================= */
useEffect(() => {
  let mounted = true;

  const init = async () => {
    try {
      // Tunggu session valid dulu
      const {
        data: { session },
      } = await supabase.auth.getSession();
console.log("SESSION:", session);
      if (!session) {
        setLoading(false);
        return;
      }

      await fetchUserRole();
      await fetchMenus();
    } catch (e: any) {
      if (mounted) setError(e.message);
    } finally {
      if (mounted) setLoading(false);
    }
  };

  init();

  // Listen perubahan auth (penting)
  const {

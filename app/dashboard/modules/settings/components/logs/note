SELECT
  created_at,
  action,
  module,
  detail
FROM public.user_activity_logs
ORDER BY created_at DESC
LIMIT 10;


select schemaname, tablename
from pg_tables
where tablename ilike '%login%';

select tablename from pg_tables where schemaname = 'public';

Cek struktur user_login_logs
select column_name, data_type
from information_schema.columns
where table_name = 'user_login_logs';


✅ QUERY MIGRASI FINAL (AMAN & SEKALI JALAN)
insert into public.user_activity_logs (
  user_id,
  email,
  action,
  module,
  detail,
  created_at
)
select
  l.user_id,
  u.email,
  case
    when l.status = 'success' then 'login_success'
    else 'login_failed'
  end as action,
  'auth' as module,
  jsonb_build_object(
    'source', 'user_login_logs',
    'device', l.device,
    'ip_address', l.ip_address,
    'user_agent', l.user_agent,
    'remember_me', l.remember_me,
    'failure_reason', l.failure_reason
  ) as detail,
  l.login_at as created_at
from public.user_login_logs l
left join auth.users u
  on u.id = l.user_id;

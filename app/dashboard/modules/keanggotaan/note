FLOW VISUAL KESELURUHAN
[ Foto Profil + Identitas ]
[ Tabs (KYU | MSH | Pelatihan) ]
[ Konten Tab (scroll) ]

SELECT
  policyname,
  cmd,
  qual
FROM pg_policies
WHERE tablename = 'profiles';

SELECT
  id,
  user_id,
  nama,
  ranting_id
FROM profiles;

SELECT
  p.nama,
  r.nama AS nama_ranting
FROM profiles p
LEFT JOIN ranting r ON r.id = p.ranting_id;

select column_name, data_type
from information_schema.columns
where table_name = 'keanggotaan';

SELECT
  tc.constraint_name,
  tc.table_name,
  kcu.column_name,
  ccu.table_name AS ref_table
FROM information_schema.table_constraints tc
JOIN information_schema.key_column_usage kcu
  ON tc.constraint_name = kcu.constraint_name
JOIN information_schema.constraint_column_usage ccu
  ON ccu.constraint_name = tc.constraint_name
WHERE tc.constraint_name = 'profiles_ranting_fk';
